# ============================================
# 콘트렉체커 환경변수
# 이 파일을 .env.local로 복사하여 사용하세요
# ============================================

# Mock/Real 서비스 전환 (true=Mock 사용, false=실제 API 사용)
USE_MOCK=true

# AWS 설정 (추후 Textract OCR 사용 시)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2

# 법원 등기정보광장 API (추후 빚 체크 사용 시)
REGISTRY_API_KEY=
REGISTRY_API_BASE_URL=https://openapi.iros.go.kr

# 국토교통부 실거래가 API (추후 시세 체크 사용 시)
MOLIT_API_KEY=

# 한국부동산원 API (추후 시세 체크 사용 시)
KREB_API_KEY=

# OpenAI API (추후 판단 AI 사용 시)
OPENAI_API_KEY=
